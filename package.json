{
  "name": "@sparklytics/next",
  "version": "0.3.0",
  "description": "Official Next.js SDK for Sparklytics analytics",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format cjs,esm --dts",
    "prepare": "npm run build",
    "dev": "tsup src/index.ts src/server.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "happy-dom": "^14.0.0",
    "next": "^16.1.6",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.2.4",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "analytics",
    "nextjs",
    "sparklytics",
    "privacy",
    "self-hosted"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sparklytics/sparklytics-next.git"
  },
  "bugs": {
    "url": "https://github.com/Sparklytics/sparklytics/issues"
  },
  "homepage": "https://sparklytics.dev",
  "engines": {
    "node": ">=18.0.0"
  }
}
